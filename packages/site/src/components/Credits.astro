---
import { AUTHOR_URL, X_URL, LINKEDIN_URL } from '../data/site';

interface Props {
  name?: string;
  url?: string;
  x?: string;
  linkedin?: string;
}

const { name = 'Derek Herman', url = AUTHOR_URL, x = X_URL, linkedin = LINKEDIN_URL } = Astro.props;
---

<div class="credits">
  Created by: <a href={url} rel="noopener noreferrer" data-track="author">{name}</a>
  <span class="sep">&middot;</span>
  <a href={x} class="social" aria-label="X (Twitter)" rel="noopener noreferrer" data-track="x">
    <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" aria-hidden="true"
      ><path
        d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
      ></path></svg
    >
  </a>
  <a
    href={linkedin}
    class="social"
    aria-label="LinkedIn"
    rel="noopener noreferrer"
    data-track="linkedin"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" aria-hidden="true"
      ><path
        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
      ></path></svg
    >
  </a>
</div>

<style>
  .credits {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-3);
    background: oklch(0 0 0 / 0.3);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  :global([data-theme='light']) .credits {
    color: var(--text-2);
    background: oklch(1 0 0 / 0.3);
  }

  .credits a {
    color: var(--text-2);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  :global([data-theme='light']) .credits a {
    color: var(--text-1);
  }

  .credits a:hover {
    color: var(--accent);
  }

  .social {
    display: inline-flex;
    color: var(--text-3);
    margin-right: var(--space-1);
    transition: color var(--duration-fast) ease;
  }

  .social:last-child {
    margin-right: 0;
  }

  .social:hover {
    color: var(--accent);
  }

  .sep {
    color: var(--text-3);
  }
</style>
