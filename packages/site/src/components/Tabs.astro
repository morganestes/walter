    class="tab tab-icon"
    role="tab"
    id="tab-cursor"
    aria-selected="false"
    aria-controls="panel-cursor"
    data-tab="cursor"
    aria-label="Cursor"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
      ><path
        fill="currentColor"
        d="M11.503.131 1.891 5.678a.84.84 0 0 0-.42.726v11.188c0 .3.162.575.42.724l9.609 5.55a1 1 0 0 0 .998 0l9.61-5.55a.84.84 0 0 0 .42-.724V6.404a.84.84 0 0 0-.42-.726L12.497.131a1.01 1.01 0 0 0-.996 0M2.657 6.338h18.55c.263 0 .43.287.297.515L12.23 22.918c-.062.107-.229.064-.229-.06V12.335a.59.59 0 0 0-.295-.51l-9.11-5.257c-.109-.063-.064-.23.061-.23"
      ></path></svg
    >
  </button>
  <button
    class="tab tab-icon"
    role="tab"
    id="tab-codex"
    aria-selected="false"
    aria-controls="panel-codex"
    data-tab="codex"
    aria-label="Codex CLI"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
      ><path
        fill="currentColor"
        d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"
      ></path></svg
    >
  </button>
</nav>

<div class="panels">
  <div
    class="panel active"
    role="tabpanel"
    id="panel-skill"
    aria-labelledby="tab-skill"
    data-panel="skill"
  >
    <p class="panel-intro">
      The foundation. One skill that gives your agent a complete engineering methodology. Commands
      and agents build on top of it.
    </p>
    <div class="skill-invoke">
      <code class="skill-command">/walter</code>
      <span class="skill-invoke-desc">Loads the skill and core references.</span>
    </div>
    <dl class="skill-refs">
      <dt class="skill-label">Core References</dt>
      <dd class="skill-detail">
        How to think about problems, manage process, hand off context between sessions, and navigate
        the development lifecycle.
      </dd>
      <dt class="skill-label">Activated by Commands</dt>
      <dd class="skill-detail">
        Planning, breaking down work, building, verifying quality, debugging, managing change,
        handling incidents, and domain-specific knowledge.
      </dd>
    </dl>
  </div>

  <dl
    class="panel"
    role="tabpanel"
    id="panel-commands"
    aria-labelledby="tab-commands"
    data-panel="commands"
    hidden
  >
    <p class="panel-intro">
      Each command handles a different phase of work and loads the right methodology, from scoping
      and breaking down problems to building, verifying, debugging, and managing incidents.
    </p>
    <div class="panel-item"><dt>/formula</dt><dd>Define the problem before solving it</dd></div>
    <div class="panel-item"><dt>/prep</dt><dd>Break it into manageable pieces</dd></div>
    <div class="panel-item"><dt>/cook</dt><dd>Build — incremental, tested, disciplined</dd></div>
    <div class="panel-item"><dt>/purity</dt><dd>Verify the work matches the intent</dd></div>
    <div class="panel-item"><dt>/stash</dt><dd>Save context for the next session</dd></div>
    <div class="panel-item"><dt>/probe</dt><dd>Research before committing</dd></div>
    <div class="panel-item"><dt>/trace</dt><dd>Find the root cause, not the symptom</dd></div>
    <div class="panel-item"><dt>/vent</dt><dd>Contain damage, recover, prevent repeats</dd></div>
    <div class="panel-item"><dt>/adapt</dt><dd>Handle changes without blowing things up</dd></div>
  </dl>

  <dl
    class="panel"
    role="tabpanel"
    id="panel-agents"
    aria-labelledby="tab-agents"
    data-panel="agents"
    hidden
  >
    <p class="panel-intro">
      Six specialists with distinct perspectives, dispatched individually or as coordinated teams.
      They run in parallel, keeping your main context clean while handling research, security,
      debugging, and architecture.
    </p>
    <div class="panel-item"><dt>Jesse</dt><dd>Research, verification, assessment</dd></div>
    <div class="panel-item"><dt>Mike</dt><dd>Security, operations, loose ends</dd></div>
    <div class="panel-item"><dt>Hank</dt><dd>Relentless root cause analysis</dd></div>
    <div class="panel-item"><dt>Gus</dt><dd>Strategic risk, long-term consequences</dd></div>
    <div class="panel-item">
      <dt>Heisenberg</dt><dd>Deep architecture, system-level assessment</dd>
    </div>
    <div class="panel-item">
      <dt>Skyler</dt><dd>Devil's advocate, product thinking, communication</dd>
    </div>
  </dl>

  {
    providers.map((p) => (
      <div
        class="panel"
        role="tabpanel"
        id={`panel-${p.id}`}
        aria-labelledby={`tab-${p.id}`}
        data-panel={p.id}
        hidden
      >
        <ProviderPanel provider={p} />
      </div>
    ))
  }
</div>

<script>
  import { trackEvent } from '../lib/analytics';

  const panelsContainer = document.querySelector<HTMLElement>('.panels')!;

  function activateTab(tabName: string) {
    trackEvent('tab_click', { tab: tabName });
    const startHeight = panelsContainer.offsetHeight;

    document.querySelectorAll('.tabs .tab').forEach((t) => {
      t.classList.remove('active');
      t.setAttribute('aria-selected', 'false');
    });
    document.querySelectorAll('.panels .panel').forEach((p) => {
      p.classList.remove('active');
      (p as HTMLElement).hidden = true;
    });

    const tab = document.querySelector(`.tab[data-tab="${tabName}"]`);
    const panel = document.querySelector(`.panel[data-panel="${tabName}"]`) as HTMLElement | null;
    if (tab) {
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
    }
    if (panel) {
      panel.classList.add('active');
      panel.hidden = false;
    }

    panelsContainer.style.height = 'auto';
    const endHeight = panelsContainer.offsetHeight;
    panelsContainer.style.height = startHeight + 'px';
    void panelsContainer.offsetHeight;
    panelsContainer.style.height = endHeight + 'px';
  }

  panelsContainer.addEventListener('transitionend', () => {
    panelsContainer.style.height = '';
  });

  const tabNav = document.querySelector('.tabs');

  tabNav?.addEventListener('click', (e) => {
    const tab = (e.target as HTMLElement).closest('.tab') as HTMLButtonElement | null;
    if (tab?.dataset.tab) activateTab(tab.dataset.tab);
  });

  // Swipe support for mobile tab cycling
  let touchStartX = 0;
  let touchStartY = 0;

  panelsContainer.addEventListener(
    'touchstart',
    (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    },
    { passive: true }
  );

  panelsContainer.addEventListener(
    'touchend',
    (e) => {
      const deltaX = e.changedTouches[0].clientX - touchStartX;
      const deltaY = e.changedTouches[0].clientY - touchStartY;

      // Only trigger on primarily horizontal swipes exceeding threshold
      if (Math.abs(deltaX) < 50 || Math.abs(deltaY) > Math.abs(deltaX)) return;

      const tabs = Array.from(document.querySelectorAll('.tabs .tab')) as HTMLButtonElement[];
      const current = tabs.findIndex((t) => t.classList.contains('active'));
      const next =
        deltaX < 0 ? (current + 1) % tabs.length : (current - 1 + tabs.length) % tabs.length;

      if (tabs[next]?.dataset.tab) {
        activateTab(tabs[next].dataset.tab!);
      }
    },
    { passive: true }
  );

  document.addEventListener('keydown', (e) => {
    const { key } = e;
    if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(key)) return;

    const active = document.activeElement;
    const isUnfocused = !active || active === document.body;
    const isTabFocused = tabNav?.contains(active);
    if (!isUnfocused && !isTabFocused) return;

    const tabs = Array.from(document.querySelectorAll('.tabs .tab')) as HTMLButtonElement[];
    const current = tabs.findIndex((t) => t.classList.contains('active'));
    let next = -1;

    if (key === 'ArrowRight') next = (current + 1) % tabs.length;
    if (key === 'ArrowLeft') next = (current - 1 + tabs.length) % tabs.length;
    if (key === 'Home') next = 0;
    if (key === 'End') next = tabs.length - 1;

    if (next >= 0 && tabs[next].dataset.tab) {
      e.preventDefault();
      activateTab(tabs[next].dataset.tab!);
      if (isTabFocused) tabs[next].focus();
    }
  });
</script>

<style>
  /* ── Tabs ── */
  .tabs {
    display: flex;
    gap: var(--space-1);
    margin-top: var(--space-6);
    border-bottom: 1px solid var(--border-1);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .tabs::-webkit-scrollbar {
    display: none;
  }

  .tab {
    background: none;
    border: none;
    border-top: 2px solid transparent;
    border-bottom: 2px solid transparent;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-3);
    padding: var(--space-2) var(--space-2) var(--space-3);
    margin-bottom: -1px;
    cursor: pointer;
    transition:
      color var(--duration-fast) ease,
      border-color var(--duration-fast) ease;
  }

  .tab:hover {
    color: var(--text-2);
  }

  .tab:focus-visible {
    outline: none;
    border-top-color: var(--accent);
  }

  .tab.active {
    color: var(--accent);
    border-top-color: var(--accent);
    border-bottom-color: var(--bg-surface);
  }

  .tab-icon {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
  }

  .tab-icon svg {
    width: 18px;
    height: 18px;
  }

  .tab-divider {
    width: 1px;
    height: 14px;
    background: var(--border-1);
    align-self: center;
    margin: 0 var(--space-1);
  }

  /* ── Panels ── */
  .panels {
    margin-top: var(--space-3);
    transition: height var(--duration-expand) ease;
    overflow: hidden;
  }

  .panel[hidden] {
    display: none;
  }

  .panel.active {
    animation: panelIn var(--duration-normal) ease;
  }

  @keyframes panelIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .panel-item {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-1) 0;
  }

  .panel-item dt {
    color: var(--accent);
    flex-shrink: 0;
    min-width: 12ch;
  }

  .panel-item dd {
    color: var(--text-2);
    font-size: var(--text-xs);
  }

  /* ── Skill Panel ── */
  .panel-intro {
    font-size: var(--text-xs);
    color: var(--text-2);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-1);
  }

  .skill-invoke {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-1);
  }

  .skill-command {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent);
    background: none;
    padding: 0;
    min-width: 12ch;
  }

  .skill-invoke-desc {
    font-size: var(--text-xs);
    color: var(--text-2);
  }

  .skill-refs {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .skill-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent);
  }

  .skill-detail + .skill-label {
    margin-top: var(--space-3);
  }

  .skill-detail {
    font-size: var(--text-xs);
    color: var(--text-2);
    line-height: var(--leading-relaxed);
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .skill-invoke,
    .panel-item {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
