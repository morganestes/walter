---
import type { Provider } from '../data/providers';
import ProviderPanel from './ProviderPanel.astro';

interface Props {
  providers: Provider[];
}

const { providers } = Astro.props;
---

<nav class="tabs" role="tablist" aria-label="Terminal content">
  <button
    class="tab active"
    role="tab"
    id="tab-skill"
    aria-selected="true"
    aria-controls="panel-skill"
    data-tab="skill">Skill</button
  >
  <button
    class="tab"
    role="tab"
    id="tab-commands"
    aria-selected="false"
    aria-controls="panel-commands"
    data-tab="commands">Commands</button
  >
  <button
    class="tab"
    role="tab"
    id="tab-agents"
    aria-selected="false"
    aria-controls="panel-agents"
    data-tab="agents">Agents</button
  >
  <span class="tab-divider"></span>
  <button
    class="tab tab-icon"
    role="tab"
    id="tab-claude"
    aria-selected="false"
    aria-controls="panel-claude"
    data-tab="claude"
    aria-label="Claude Code"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
      ><path
        fill="currentColor"
