      ></path></svg
    >
  </button>
  <button
    class="tab tab-icon"
    role="tab"
    id="tab-gemini"
    aria-selected="false"
    aria-controls="panel-gemini"
    data-tab="gemini"
    aria-label="Gemini CLI"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
      ><path
