---
/**
 * Full-bleed background with pre-filtered desert images.
 * - <picture> handles format (WebP/JPEG) and responsive (mobile/desktop) natively
 * - JS handles theme switching only (data-theme attribute)
 * Images generated by: node scripts/optimize-bg.js
 */
---

<div class="bg-wrap" aria-hidden="true">
  <picture class="bg">
    <source
      media="(max-width: 768px)"
      srcset="/assets/bg/desert-dark-mobile.webp"
      type="image/webp"
      data-dark="/assets/bg/desert-dark-mobile.webp"
      data-light="/assets/bg/desert-light-mobile.webp"
    />
    <source
      media="(max-width: 768px)"
      srcset="/assets/bg/desert-dark-mobile.jpg"
      type="image/jpeg"
      data-dark="/assets/bg/desert-dark-mobile.jpg"
      data-light="/assets/bg/desert-light-mobile.jpg"
    />
    <source
      srcset="/assets/bg/desert-dark.webp"
      type="image/webp"
      data-dark="/assets/bg/desert-dark.webp"
      data-light="/assets/bg/desert-light.webp"
    />
    <img
      src="/assets/bg/desert-dark.jpg"
      data-dark="/assets/bg/desert-dark.jpg"
      data-light="/assets/bg/desert-light.jpg"
      alt=""
      loading="eager"
    />
  </picture>
  <div class="glow"></div>
</div>

<style>
  .bg-wrap {
    position: fixed;
    inset: 0;
    z-index: -1;
  }
  .bg {
    position: absolute;
    inset: 0;
  }

  .bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ── Atmospheric glow ── */
  .glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at 45% 33%,
      oklch(0.22 0.01 250 / 0.3),
      oklch(0.19 0.005 250 / 0.12) 35%,
      transparent 60%
    );
  }

  :global([data-theme='light']) .glow {
    background: radial-gradient(
      ellipse at 45% 33%,
      oklch(0.97 0.06 80 / 0.4),
      oklch(0.94 0.03 75 / 0.2) 25%,
      transparent 30%
    );
  }
</style>

<script>
  function updateTheme() {
    const theme = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
    const pic = document.querySelector('picture.bg');
    if (!pic) return;

    pic.querySelectorAll('source').forEach((source) => {
      const url = source.dataset[theme];
      if (url) source.srcset = url;
    });

    const img = pic.querySelector('img') as HTMLImageElement;
    if (img) {
      const url = img.dataset[theme];
      if (url) img.src = url;
    }
  }

  updateTheme();
  new MutationObserver(updateTheme).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme']
  });
</script>
