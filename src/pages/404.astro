---
import Base from '../layouts/Base.astro';
import Background from '../components/Background.astro';
import Terminal from '../components/Terminal.astro';
import Credits from '../components/Credits.astro';
---

<Base title="Walter - 404: Page Not Found">
  <div class="error-page">
    <Background />
    <Terminal path="~/walter/404">
      <div class="output">
        <p class="code">404: <em>Page Not Found</em></p>
        <p class="tagline">Contaminated batch.</p>
        <p class="detail">This page doesn't exist. The formula was wrong,</p>
        <p class="detail">or someone moved the product.</p>
      </div>
      <a href="/" class="error-link">Back to the lab &rarr;</a>
    </Terminal>
    <Credits />
  </div>
</Base>

<style>
  .error-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    position: relative;
    overflow: hidden;
  }

  .output {
    margin-top: var(--space-4);
  }

  .code {
    color: var(--error);
    margin: 0;
  }

  .code em {
    color: var(--text-1);
    font-style: normal;
  }

  .tagline {
    color: var(--text-2);
    margin-top: var(--space-3);
  }

  .detail {
    color: var(--text-3);
    margin: 0;
  }

  .error-link {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--space-6);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--bg-page);
    background: var(--accent);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: opacity var(--duration-fast) ease;
  }

  .error-link:hover {
    opacity: 0.85;
    color: var(--bg-page);
  }

  @media (max-width: 600px) {
    .error-page {
      min-height: 100svh;
      justify-content: flex-start;
    }
  }
</style>
